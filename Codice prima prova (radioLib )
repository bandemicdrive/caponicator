/*
  RadioLib SX126x Ping-Pong 
  For default module settings, see the wiki page
  https://github.com/jgromes/RadioLib/wiki/Default-configuration#sx126x---lora-modem

  For full API reference, see the GitHub Pages
  https://jgromes.github.io/RadioLib/
*/

// include the library
#include <RadioLib.h>

// uncomment the following only on one
// of the nodes to initiate the pings 
//#de fine INITIATING_NODE                       //+++++      +++++++   +++++++  ***********

// SX1262 has the following connections:
// (NSS pin, DIO1 pin, NRST pin, BUSY pin)
SX1262 radio = new Module(8, 14, 12, 13);



// save transmission states between loops
int transmissionState = RADIOLIB_ERR_NONE;
// flag to indicate transmission or reception state
bool transmitFlag = false;
// flag to indicate that a packet was sent or received
volatile bool operationDone = false;

unsigned long lastActionTime = 0;
const unsigned long TIMEOUT_INTERVAL = 5000; // 5 secondi di timeout




// this function is called when a complete packet
// is transmitted or received by the module
// IMPORTANT: this function MUST be 'void' type
//            and MUST NOT have any arguments!
#if defined(ESP8266) || defined(ESP32)  //serve a dire al compilatore: "Se il codice sta girando su un ESP8266
  ICACHE_RAM_ATTR                       // o un ESP32, carica la funzione che segue direttamente nella RAM 
#endif                                  //invece che nella memoria Flash."

// we sent or received a packet, set the flag
void setFlag(void) {
  operationDone = true;
}

void setup() {
  Serial.begin(115200);

  // initialize SX1262 
  Serial.print(F("[SX1262] Initializing ... "));
  int state = radio.begin();
  if (state == RADIOLIB_ERR_NONE) {
    state = radio.setFrequency(868.0);        //-------   -------    --------
    state = radio.setBandwidth(125.0);        //-------
    state = radio.setSpreadingFactor(9);      //-------
    state = radio.setCodingRate(7);           //-------
    state = radio.setSyncWord(0x12);
    state = radio.setOutputPower(8);      //------- !!!!  !!!!   !!!!!
    state = radio.setPreambleLength(8);
    Serial.println(F("success!"));            
  } else {
    Serial.print(F("failed, code "));
    Serial.println(state);
    while (true) { delay(10); }
  }

  // set the function that will be called
  // when new packet is received
  radio.setDio1Action(setFlag);

  #if defined(INITIATING_NODE)
    // send the first packet on this node
    Serial.print(F("[SX1262] Sending first packet ... "));
    transmissionState = radio.startTransmit("Aloha");
    transmitFlag = true;
  #else
    // start listening for LoRa packets on this node
    Serial.print(F("[SX1262] Starting to listen ... "));
    state = radio.startReceive();
    if (state == RADIOLIB_ERR_NONE) {
      Serial.println(F("success!"));
    } else {
      Serial.print(F("failed, code "));
      Serial.println(state);
      while (true) { delay(10); }
    }
  #endif
}

void loop() {
  // 1. Gestione del TIMEOUT
  if (!operationDone && (millis() - lastActionTime > TIMEOUT_INTERVAL)) {
    
    #if defined(INITIATING_NODE)
      // L'iniziatore non ha ricevuto risposta: riprova l'invio
      Serial.println(F("[SX1262] Timeout! Nessuna risposta. Riprovo l'invio..."));
      transmissionState = radio.startTransmit("Aloha");
      transmitFlag = true; 
    #else
      // Il nodo secondario torna semplicemente in ascolto
      Serial.println(F("[SX1262] Timeout: nessun segnale. Riavvio ricezione..."));
      int state = radio.startReceive();
      if (state != RADIOLIB_ERR_NONE) {
        Serial.print(F("Errore di riavvio ricezione, codice: "));
        Serial.println(state);
      }
      transmitFlag = false;
    #endif

    lastActionTime = millis(); // Reset del timer per il prossimo ciclo
  }

  // 2. Gestione dell'OPERAZIONE COMPLETATA (Interrupt)
  if (operationDone) {
    operationDone = false; // Reset del flag di interrupt
    lastActionTime = millis(); // Aggiorniamo il tempo dell'ultima operazione riuscita

    if (transmitFlag) {
      // --- Eravamo in trasmissione ---
      if (transmissionState == RADIOLIB_ERR_NONE) {
        Serial.println(F("Trasmissione completata!"));
      } else {
        Serial.print(F("Errore trasmissione, codice: "));
        Serial.println(transmissionState);
      }

      // Dopo aver trasmesso, passiamo in ricezione
      radio.startReceive();
      transmitFlag = false;

    } else {
      // --- Eravamo in ricezione ---
      String str;
      int state = radio.readData(str);

      if (state == RADIOLIB_ERR_NONE) {
        Serial.println(F("[SX1262] Pacchetto ricevuto:"));
        Serial.println(str);
        Serial.print(F("RSSI: ")); Serial.print(radio.getRSSI()); Serial.println(F(" dBm"));
        Serial.print(F("SNR: ")); Serial.print(radio.getSNR()); Serial.println(F(" dB"));
      }

      // Breve pausa prima di rispondere,
      delay(300);

      // Rispondiamo al mittente
      Serial.print(F("[SX1262] Invio risposta... "));
      transmissionState = radio.startTransmit("aloha");
      transmitFlag = true;
    }
  }
}
