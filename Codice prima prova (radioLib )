/*
  RadioLib SX126x Ping-Pong 

  codice brutto ma funziona, led sul pin 35, attivazione pin FEM
  potenza bassa, questi risultati dall'altra parte della casa con ostacoli:
    SX1262] Pacchetto ricevuto:
    RSSI: -51.00 dBm  
    SNR: -0.25 dB
  fin troppa  a 8 !  con poca piu potenza assordi ricevitore!!!
  occhio a casa!! . domani provo outdoor
  
  una scheda iniziatrice (decommentare #define INITIATING_NODE) invia messaggio e si mette in ascolto.
   dopo 5 sec riprova. se riceve risposta comincia ping pong con scheda ricevente.

   pensato di fare prime prove  con iniziatrice a casa con monitor seriale acceso per telemetria
    e l'altra in giro da accendere ogni tanto per vedere se riceve (dal led che lampeggia) 

*/

#include <RadioLib.h>

// DECOMMENTA SOLO SU UNA DELLE DUE SCHEDE

//#define INITIATING_NODE

// Pinout Heltec LoRa 32 V4 (SX1262)
const int NSS_PIN = 8;
const int DIO1_PIN = 14;
const int NRST_PIN = 12;
const int BUSY_PIN = 13;
const int LED_PIN = 35;
const int FEM_EN = 7; // Pin abilitazione RF (solo per V4)

SX1262 radio = new Module(NSS_PIN, DIO1_PIN, NRST_PIN, BUSY_PIN);

volatile bool operationDone = false;
bool transmitFlag = false;
unsigned long lastActionTime = 0;
const unsigned long TIMEOUT_INTERVAL = 5000;

bool waitingToRespond = false;      // Flag: abbiamo ricevuto qualcosa e dobbiamo rispondere?
unsigned long responseStartTime = 0; // Quando abbiamo ricevuto il pacchetto?
const unsigned long RESPONSE_DELAY = 2000; // Pausa di 2 secondi prima di inviare Ack

#if defined(ESP8266) || defined(ESP32)
  ICACHE_RAM_ATTR
#endif
void setFlag(void) {
  operationDone = true;
}

void setup() {
  Serial.begin(115200);
  pinMode(LED_PIN, OUTPUT);
  
  // ABILITA ANTENNA (Senza questo la portata è minima)
  pinMode(FEM_EN, OUTPUT);
  digitalWrite(FEM_EN, HIGH);

  Serial.print(F("[SX1262] Initializing... "));
  // Parametri: Freq: 868.0, BW: 125.0, SF: 9, CR: 7, Sync: 0x12, Pwr: 8dBm
  int state = radio.begin(868.0, 125.0, 9, 7, 0x12, 8);

  if (state == RADIOLIB_ERR_NONE) {
    Serial.println(F("OK!"));
  } else {
    Serial.print(F("Errore: ")); Serial.println(state);
    while (true);
  }

  radio.setDio1Action(setFlag);

  #if defined(INITIATING_NODE)
    Serial.println(F("MODO: INIZIATORE (Master)"));
    radio.startTransmit("Ping");
    transmitFlag = true;
  #else
    Serial.println(F("MODO: RICEVITORE (Slave)"));
    radio.startReceive();
    transmitFlag = false;
  #endif
  
  lastActionTime = millis();
}

void loop() {
  // 1. GESTIONE TIMEOUT
  if (!operationDone && (millis() - lastActionTime > TIMEOUT_INTERVAL)) {
    #if defined(INITIATING_NODE)
      radio.startTransmit("Ping");
      transmitFlag = true;
    #else
      radio.startReceive();
      transmitFlag = false;
    #endif
    lastActionTime = millis();
  }

  // 2. OPERAZIONE COMPLETATA (TX o RX)
  if (operationDone) {
    operationDone = false;
    lastActionTime = millis();

    if (transmitFlag) {
      // Fine trasmissione -> vai in ricezione
      radio.startReceive();
      transmitFlag = false;
    } else {
      // Ricezione avvenuta
      String str;
      int state = radio.readData(str);

      if (state == RADIOLIB_ERR_NONE) {
        // Telemetria compatta per monitor seriale
        Serial.print(F("RX: ")); Serial.print(str);
        Serial.print(F(" | RSSI:")); Serial.print(radio.getRSSI());
        Serial.print(F(" | SNR:")); Serial.println(radio.getSNR());

        // Feedback LED rapido
        digitalWrite(LED_PIN, HIGH);
        delay(50);
        digitalWrite(LED_PIN, LOW);
        // INVECE DI TRASMETTERE SUBITO, ATTIVIAMO IL TIMER
        waitingToRespond = true;
        responseStartTime = millis();
        
        
      }
    }
  }
  // 3. GESTIONE DELLA RISPOSTA RITARDATA (Non-bloccante)
  if (waitingToRespond && (millis() - responseStartTime >= RESPONSE_DELAY)) {
    waitingToRespond = false; // Reset flag
    
    Serial.println(F("invio Ack..."));
    radio.startTransmit("Ack");
    transmitFlag = true;
    // Non resettiamo lastActionTime qui, lo farà operationDone a fine trasmissione
  }
}
